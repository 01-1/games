encode zstd gzip

# Serve only the landing page and its known assets from the shared site directory.
# Keeping these matchers exact prevents the landing page from claiming game or
# unrelated routes when this file is imported into an existing site block.
@landing_no_slash path_regexp landing_no_slash ^{args[0]}$
redir @landing_no_slash {args[0]}/ 308

@landing_root path {args[0]}/
handle @landing_root {
	root * {args[1]}/server/site
	rewrite * /index.html
	file_server
}

@landing_styles path {args[0]}/styles.css
handle @landing_styles {
	root * {args[1]}/server/site
	rewrite * /styles.css
	file_server
}

@landing_app path {args[0]}/app.js
handle @landing_app {
	root * {args[1]}/server/site
	rewrite * /app.js
	file_server
}

@sleeper_agent_root path {args[0]}/sleeper-agent
redir @sleeper_agent_root {args[0]}/sleeper-agent/ 308
handle_path {args[0]}/sleeper-agent/* {
	root * {args[1]}/sleeper-agent
	file_server {
		hide .git .env .claude .agents .codex tests README.md AGENTS.md package.json package-lock.json
	}
}

@checkpoint_root path {args[0]}/checkpoint
redir @checkpoint_root {args[0]}/checkpoint/ 308
handle_path {args[0]}/checkpoint/* {
	root * {args[1]}/checkpoint
	file_server {
		hide .git .env .claude .agents .codex tests README.md AGENTS.md package.json package-lock.json
	}
}

@inverse_root path {args[0]}/inverse
redir @inverse_root {args[0]}/inverse/ 308
handle_path {args[0]}/inverse/* {
	root * {args[1]}/inverse/dist
	try_files {path} /index.html
	file_server
}

@money_game_root path {args[0]}/tragistea
redir @money_game_root {args[0]}/tragistea/ 308
handle_path {args[0]}/tragistea/* {
	root * {args[1]}/money-game
	file_server {
		hide .git .env .claude .agents .codex tests README.md AGENTS.md package.json package-lock.json
	}
}

# The public slug changed when the repository entered the workspace manifest.
# Keep old bookmarks working while making tragistea/ the canonical route.
@money_game_legacy_root path {args[0]}/money-game
redir @money_game_legacy_root {args[0]}/tragistea/ 308
handle_path {args[0]}/money-game/* {
	redir {args[0]}/tragistea{path} 308
}

@scratchpad_root path {args[0]}/scratchpad
redir @scratchpad_root {args[0]}/scratchpad/ 308
handle_path {args[0]}/scratchpad/* {
	reverse_proxy 127.0.0.1:7410
}

@colluders_root path {args[0]}/the-colluders
redir @colluders_root {args[0]}/the-colluders/ 308
handle_path {args[0]}/the-colluders/* {
	reverse_proxy 127.0.0.1:7411
}

@debate_root path {args[0]}/the-debate
redir @debate_root {args[0]}/the-debate/ 308
handle_path {args[0]}/the-debate/* {
	reverse_proxy 127.0.0.1:7412
}

@turnover_root path {args[0]}/turnover
redir @turnover_root {args[0]}/turnover/ 308
handle_path {args[0]}/turnover/* {
	reverse_proxy 127.0.0.1:7413
}

@still_there_root path {args[0]}/still-there
redir @still_there_root {args[0]}/still-there/ 308
handle_path {args[0]}/still-there/* {
	root * {args[1]}/still-there
	try_files {path} /index.html
	file_server {
		hide .git .env .claude .agents .codex AGENTS.md package.json package-lock.json
	}
}

@weak_supervisor_root path {args[0]}/weak-supervisor
redir @weak_supervisor_root {args[0]}/weak-supervisor/ 308
handle_path {args[0]}/weak-supervisor/* {
	root * {args[1]}/weak-supervisor/dist
	try_files {path} /index.html
	file_server
}
